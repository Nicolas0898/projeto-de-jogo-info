[resource]
script = ExtResource("1_ff865")
nome = "Golem de Terra"
subtitle = "Seu maior inimigo"
desc = "A anos atrás, para se proteger de uma eventual guerra, o povo das cavernas criou um batalhão de golens e pôs eles para proteger as entradas e saídas do pântano. Eles foram \"acordados\" com energia dos fragmentos, e com o tempo, a mesma se dissipou e os golens apagaram, mas pelo visto um ainda ficou acordado."
