[ext_resource type="Script" uid="uid://cvcbjk1q6vmty" path="res://Scripts/ETC/bestiary_label.gd" id="1_cpmud"]

[resource]
script = ExtResource("1_cpmud")
text = "Dizem que o Golem de Terra é um dos seres mais poderosos de todo o pântano. Com seu corpo feito de pedra e sua harmonia com a natureza, o Golem mantém o pântano protegido."
