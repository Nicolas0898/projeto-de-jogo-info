; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Movimentação"
run/main_scene="uid://cwrl44jwaopp4"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameHandler="*res://Scripts/Global/GameHandler.gd"
InteractionSystem="*res://script/interact/InteractionSystem.gd"
Ui="*res://scenes/ui.tscn"
NavigationManager="*res://Scripts/Global/NavigationManager.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="canvas_items"
window/vsync/vsync_mode=0
window/canvas_textures/default_texture_filter=0

[file_customization]

folder_colors={
"res://Images/": "red",
"res://Scenes/": "orange",
"res://Scripts/": "yellow"
}

